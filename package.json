{
  "name": "vanehub-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "icons:generate": "node scripts/generate-vanehub-icon.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package": "tauri build",
    "package:windows:x64": "tauri build --target x86_64-pc-windows-msvc",
    "package:windows:arm64": "tauri build --target aarch64-pc-windows-msvc",
    "package:macos:x64": "tauri build --target x86_64-apple-darwin",
    "package:macos:arm64": "tauri build --target aarch64-apple-darwin",
    "package:linux:x64": "tauri build --target x86_64-unknown-linux-gnu",
    "package:linux:arm64": "tauri build --target aarch64-unknown-linux-gnu",
    "version:check": "node scripts/check-version-sync.mjs",
    "test": "vitest run",
    "contracts:check": "vitest run src/contracts/contract-conformance.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.101.4",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.6",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.82.0",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.21.5": true
  }
}
